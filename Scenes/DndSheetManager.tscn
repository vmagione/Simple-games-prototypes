[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://Scripts/dnd_sheet_manager_game.gd" id="1_dnd"]

[node name="DndSheetManager" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_dnd")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.07, 0.06, 0.09, 1)

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 60
theme_override_constants/margin_top = 36
theme_override_constants/margin_right = 60
theme_override_constants/margin_bottom = 36

[node name="ListPanel" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="MarginContainer/ListPanel"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Gerenciador de Fichas D&D 5e"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="MarginContainer/ListPanel"]
layout_mode = 2
